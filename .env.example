APP_NAME=InkApi
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

# API App Token - Required for all API requests (set in production)
# Generate with: php artisan tinker --execute="echo bin2hex(random_bytes(32));"
API_APP_TOKEN=

# User Online Status Settings
USER_ONLINE_TIMEOUT_MINUTES=5
USER_LAST_SEEN_THROTTLE_MINUTES=1

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=inkedin
DB_USERNAME=sail
DB_PASSWORD=password

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Sanctum Token Expiration (minutes)
# Set to null or omit for no expiration (tokens last until logout)
# Common values: 60 (1 hour), 1440 (24 hours), 10080 (7 days), 43200 (30 days)
# SANCTUM_TOKEN_EXPIRATION=

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
S3_FILE_PREFIX=dev

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Elasticsearch settings
ELASTICSEARCH_HOST=http://elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=tattoos
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_TIMEOUT=200
ELASTICSEARCH_CONNECT_TIMEOUT=200
ELASTIC_UPDATE_MAPPING=false
ELASTIC_INDEXER=single
ELASTIC_SNAP_REPO=cs-automated-enc

# Sail settings
WWWUSER=1000
WWWGROUP=1000

# XDebug settings
SAIL_XDEBUG_MODE=develop,debug,coverage
SAIL_XDEBUG_CONFIG="client_host=host.docker.internal client_port=9003 idekey=docker"

# Telescope settings
TELESCOPE_ENABLED=true

# CORS settings (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,https://your-app.vercel.app

# Firebase Cloud Messaging (Push Notifications)
FCM_PROJECT_ID=
FCM_CREDENTIALS=