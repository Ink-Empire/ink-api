APP_NAME=InkApi
APP_ENV=testing
APP_KEY=base64:test1234567890123456789012345678901234567890
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

# Disable app token for tests
API_APP_TOKEN=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# IMPORTANT: Use a separate test database to avoid dropping local data
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=inkedin_test
DB_USERNAME=sail
DB_PASSWORD=password

# Use array/sync drivers for testing (no external services needed)
BROADCAST_DRIVER=log
CACHE_DRIVER=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

MAIL_MAILER=array

# Disable Telescope and Pulse in tests
TELESCOPE_ENABLED=false
PULSE_ENABLED=false

# Elasticsearch - use test index
ELASTICSEARCH_HOST=http://elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=tattoos_test
ELASTICSEARCH_ARTISTS_INDEX=artists_test
ELASTICSEARCH_TATTOOS_INDEX=tattoos_test
SCOUT_DRIVER=null
